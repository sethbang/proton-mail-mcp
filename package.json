{
  "name": "proton-mail-mcp",
  "version": "0.1.0",
  "description": "MCP server for Proton Mail — send, read, and search email over SMTP and IMAP",
  "repository": {
    "type": "git",
    "url": "https://github.com/sethbang/proton-mail-mcp.git"
  },
  "homepage": "https://github.com/sethbang/proton-mail-mcp#readme",
  "bugs": {
    "url": "https://github.com/sethbang/proton-mail-mcp/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "bin": {
    "proton-mail-mcp": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "imapflow": "^1.3.1",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}

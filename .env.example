## SMTP (Proton Mail direct or via Bridge)
PROTONMAIL_USERNAME=your-email@protonmail.com
PROTONMAIL_PASSWORD=your-smtp-password
PROTONMAIL_HOST=smtp.protonmail.ch
PROTONMAIL_PORT=587
PROTONMAIL_SECURE=false

## IMAP (Proton Mail Bridge)
IMAP_HOST=127.0.0.1
IMAP_PORT=1143
IMAP_SECURE=false
# IMAP_USERNAME and IMAP_PASSWORD default to PROTONMAIL_USERNAME/PASSWORD if not set
# IMAP_USERNAME=your-bridge-username
# IMAP_PASSWORD=your-bridge-password

DEBUG=false

## Safety
# Set to true to disable all mutating tools (send, reply, forward, move, delete, flags)
READONLY=false

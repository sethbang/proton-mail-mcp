## SMTP (Proton Mail direct or via Bridge)
PROTONMAIL_USERNAME=your-email@protonmail.com
PROTONMAIL_PASSWORD=your-smtp-password
PROTONMAIL_HOST=smtp.protonmail.ch
PROTONMAIL_PORT=587
PROTONMAIL_SECURE=false

## IMAP (Proton Mail Bridge)
IMAP_HOST=127.0.0.1
IMAP_PORT=1143
IMAP_SECURE=false
# IMAP_USERNAME and IMAP_PASSWORD default to PROTONMAIL_USERNAME/PASSWORD if not set
# IMAP_USERNAME=your-bridge-username
# IMAP_PASSWORD=your-bridge-password

DEBUG=false

## Safety
# Set to true to disable all mutating tools (send/reply/forward, drafts, move/delete/flags/labels,
# bulk_*, create/rename/delete folders + labels, empty_folder, thread mutations). Read, search,
# and aggregation tools remain available.
READONLY=false

# Lock the send-family tools (send_email/reply_email/reply_all_email/forward_email) to
# self-sends only. When true, a live send to ANY recipient other than the authenticated
# account (PROTONMAIL_USERNAME) is refused — so agent-driven testing on a throwaway account
# can't fan real mail out to external addresses embedded in seed data. There is no per-call
# override (the env var is the gate), so a prompt-injected agent can't bypass it. Use a
# tool's `dryRun: true` to preview the resolved recipient set without sending. Off by
# default — blocking external recipients is wrong for a general-purpose mail server.
# Independent of READONLY (which disables sends entirely).
RESTRICT_OUTBOUND_TO_SELF=false

# Opt-in gate for the empty_folder tool. NOT RECOMMENDED — empty_folder permanently
# destroys Trash/Junk contents, which is the user's last line of defense against
# destructive agent actions. The Proton web UI empties Trash in two clicks, and that's
# safer than handing the capability to an LLM. Leave this off unless you have a specific
# automation that needs it. Independent of READONLY (which still disables empty_folder).
ALLOW_EMPTY_FOLDER=false

# Optional allowlist directory for download_attachment's saveTo parameter. When set,
# download_attachment can write decoded attachment bytes to disk at a relative path
# inside this directory (rejecting absolute paths, `..` traversal, and symlink escapes).
# Unset → download_attachment always returns base64 inline. Useful for very large
# attachments that would otherwise blow the token budget. Example:
#   ALLOW_FILE_DOWNLOAD_DIR=/Users/me/Downloads/mcp-attachments
# ALLOW_FILE_DOWNLOAD_DIR=
